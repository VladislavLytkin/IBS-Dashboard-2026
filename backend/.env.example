# Скопируйте в .env (или оставьте как есть - значения по умолчанию рабочие для прототипа)
PORT=4000
# Источник, которому разрешён CORS. Можно указать несколько через запятую.
CORS_ORIGIN=http://localhost:5173
# Секрет для подписи JWT. ДЛЯ ПРОДА обязательно заменить на длинный случайный.
JWT_SECRET=change-me-use-a-long-random-secret
# Время жизни токена
JWT_EXPIRES_IN=12h
# Путь к файлу JSON-хранилища прототипа
DB_FILE=./data/store.json
